<mvc:View
    controllerName="cotemar.solicitudprontospagos.controller.SolicitudDetail"
    xmlns="sap.uxap"
    xmlns:layout="sap.ui.layout"
    xmlns:m="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:cms="sap.suite.ui.commons"
>
    <ObjectPageLayout
        id="ObjectPageLayoutid"
        showTitleInHeaderContent="true"
        alwaysShowContentHeader="true"
        preserveHeaderStateOnScroll="true"
        headerContentPinnable="true"
        upperCaseAnchorBar="false"
        showFooter="{parts: ['solicitudDetail>/RELANZADO','solicitudDetail>/ID_ESTADO'],formatter: '.formatter.isFooterVisible'}"
    >
        <headerTitle>
            <ObjectPageDynamicHeaderTitle>
                <expandedHeading>
                    <m:Title
                        text="{= ${i18n>detail.titleSolicitud} + ' (' + ${solicitudDetail>/ID_SOLICITUD} + ')' + ' - ' + ${i18n>detail.titleVersion} + ' (' + ${solicitudDetail>/SOLICITUD_VERSION} + ')'}"
                        wrapping="true"
                    />
                </expandedHeading>
                <actions>
                    <m:OverflowToolbarButton
                        icon="sap-icon://decline"
                        type="Emphasized"
                        tooltip="{i18n>RequirementDetail.buttonClose}"
                        press="onCloseSolicitudDetailPress"
                    />
                </actions>
            </ObjectPageDynamicHeaderTitle>
        </headerTitle>
        <sections>
            <ObjectPageSection>
                <subSections>
                    <ObjectPageSubSection>
                        <form:SimpleForm
                            title="{i18n>detail.form.title}"
                            editable="true"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="4"
                            labelSpanL="3"
                            labelSpanM="4"
                            labelSpanS="12"
                            adjustLabelSpan="false"
                            emptySpanXL="0"
                            emptySpanL="4"
                            emptySpanM="0"
                            emptySpanS="0"
                            columnsXL="2"
                            columnsL="1"
                            columnsM="1"
                            singleContainerFullSize="false"
                        >
                            <m:Label
                                text="{i18n>master.tableColumn.document}"
                            />
                            <m:Input
                                editable="false"
                                value="{solicitudDetail>/DOCUMENT}"
                            />
                            <m:Label text="{i18n>master.tableColumn.society}" />
                            <m:Input
                                editable="false"
                                value="{= ${solicitudDetail>/SOCIETY}+' - '+${solicitudDetail>/SOCIEDAD_DESC}}"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.supplier}"
                            />
                            <m:Input
                                editable="false"
                                value="{solicitudDetail>/SUPPLIER_DESC}"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.subOfBusiness}"
                            />
                            <m:Input
                                editable="false"
                                value="{solicitudDetail>/CENTRO_COSTO}"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.applicantArea}"
                            />
                            <m:Input
                                editable="false"
                                value="{solicitudDetail>/AREA_SOLICITANTE}"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.POInvoice}"
                            />
                            <m:Input
                                editable="false"
                                value="{solicitudDetail>/ORDEN_COMPRA}"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.dateDocumentInvoice}"
                            />
                            <m:Input
                                editable="false"
                                value="{path: 'solicitudDetail>/FECHA_PARTIDA', formatter: '.formatter.formatDate'}"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.dateRequest}"
                            />
                            <m:Input
                                editable="false"
                                value="{path: 'solicitudDetail>/FECHA', formatter: '.formatter.formatDate'}"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.applicant}"
                            />
                            <m:Input
                                editable="false"
                                value="{solicitudDetail>/USUARIO}"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.expirationDate}"
                            />
                            <m:Input
                                editable="false"
                                value="{path: 'solicitudDetail>/FECHA_VENCIMIENTO', formatter: '.formatter.formatDate'}"
                            />
                            <m:Label text="{i18n>master.tableColumn.status}" />
                            <m:ObjectStatus
                                text="{solicitudDetail>/es/DESCRIPCION}"
                                state="{ path: 'solicitudDetail>/es/ID_ESTADO', formatter: '.formatter.statusColor'}"
                                icon="sap-icon://circle-task-2"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.currency}"
                            />
                            <m:Input
                                editable="false"
                                value="{solicitudDetail>/MONEDA_DESC}"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.invoiceReference}"
                            />
                            <m:Input
                                editable="false"
                                value="{solicitudDetail>/REFERENCIA}"
                            />
                            <m:Label text="{i18n>master.tableColumn.remarks}" required="true" />
                            <m:TextArea
                                editable="false"
                                value="{solicitudDetail>/REASON}"
                                growing="true"
                                growingMaxLines="7"
                                width="100%"
                            />
                        </form:SimpleForm>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection>
                <subSections>
                    <ObjectPageSubSection>
                        <form:SimpleForm
                            title="{i18n>detail.form.titleProntoPago}"
                            editable="true"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="4"
                            labelSpanL="3"
                            labelSpanM="4"
                            labelSpanS="12"
                            adjustLabelSpan="false"
                            emptySpanXL="0"
                            emptySpanL="4"
                            emptySpanM="0"
                            emptySpanS="0"
                            columnsXL="2"
                            columnsL="1"
                            columnsM="1"
                            singleContainerFullSize="false"
                        >
                            <m:Label
                                text="{i18n>master.tableColumn.datePaymentProposal}"
                            />
                            <m:Input
                                value="{path: 'solicitudDetail>/PAYMENT_DATE', formatter: '.formatter.formatDate'}"
                                editable="false"
                            />
                            <m:Label
                                text="{i18n>master.tableColumn.invoiceAmount}"
                            />
                            <m:Input
                                editable="false"
                                value="{path :'solicitudDetail>/MONEY', formatter: '.formatter.formatNumber'}"
                            />
                        </form:SimpleForm>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection>
                <subSections>
                    <ObjectPageSubSection>
                        <m:VBox>
                            <m:Toolbar>
                                <m:Title text="{i18n>detail.pf.title}" />
                                <m:ToolbarSpacer />
                                <m:Button press="onZoomInProcessFlow" icon="sap-icon://zoom-in" />
                                <m:Button press="onZoomOutProcessFlow" icon="sap-icon://zoom-out" />
                            </m:Toolbar>
                            <cms:ProcessFlow
                                id="processflow"
                                scrollable="false"
                                wheelZoomable="false"
                                nodePress="onNodePress"
                                nodes="{approversGraph>/nodes}"
                                lanes="{approversGraph>/lanes}"
                            >
                                <cms:nodes>
                                    <cms:ProcessFlowNode
                                        laneId="{approversGraph>lane}"
                                        nodeId="{approversGraph>id}"
                                        title="{approversGraph>title}"
                                        titleAbbreviation="{approversGraph>titleAbbreviation}"
                                        children="{approversGraph>children}"
                                        state="{approversGraph>state}"
                                        stateText="{approversGraph>stateText}"
                                        texts="{approversGraph>texts}"
                                        focused="{approversGraph>focused}"
                                        press="onNodePress"
                                    />
                                </cms:nodes>
                                <cms:lanes>
                                    <cms:ProcessFlowLaneHeader
                                        laneId="{approversGraph>id}"
                                        iconSrc="{approversGraph>icon}"
                                        text="{approversGraph>label}"
                                        position="{approversGraph>position}"
                                    />
                                </cms:lanes>
                            </cms:ProcessFlow>
                        </m:VBox>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
        </sections>

         <footer>
            <m:OverflowToolbar>
                <m:ToolbarSpacer />
                <m:Button

                    type="Accept"
                    text="{i18n>detail.btn.resend}"
                    press="onPressReenviarSolicitud"
                />
            </m:OverflowToolbar>
        </footer>

    </ObjectPageLayout>
</mvc:View>
